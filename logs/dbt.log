  create  table "formula_one"."dev"."int_results_enriched__dbt_tmp"
  
  
    as
  
  (
    with results as (
    select * from "formula_one"."dev"."stg_results"
),

races as (
    select * from "formula_one"."dev"."stg_races"
),

drivers as (
    select * from "formula_one"."dev"."stg_drivers"
), 

constructors as (
    select * from "formula_one"."dev"."stg_constructors"
)

select 
    races.result_id,
    races.race_id,
    races.driver_id,
    races.constructor_id,
    number,
    grid,
    "position",
    positiontext,
    positionorder,
    points,
    laps,
    "time",
    milliseconds,
    fastestlap,
    rank,
    fastestlaptime,
    fastestlapspeed,
    statusid
    year,
    round,
    circuit_id,
    race_name,
    date,
    "time",
    fp1_date,
    fp1_time,
    fp2_date,
    fp2_time,
    fp3_date,
    fp3_time,
    quali_date,
    quali_time,
    sprint_date,
    sprint_time
    driver_ref,
    driver_number,
    driver_code,
    driver_forename,
    driver_surname,
    date_of_birth,
    driver_nationality
    constructor_ref,
    constructor_name,
    constructor_nationality
from 
    results
    inner join races on results.race_id = races.race_id
    left join drivers on results.driver_id = drivers.driver_id
    left join constructors on results.constructor_id = constructors.constructor_id
  );
  
