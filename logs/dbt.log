    race_name,
    race_date,
    race_time,
    fp1_date,
    fp1_time,
    fp2_date,
    fp2_time,
    fp3_date,
    fp3_time,
    quali_date,
    quali_time,
    sprint_date,
    sprint_time
    driver_ref,
    driver_number,
    driver_code,
    driver_forename,
    driver_surname,
    date_of_birth,
    driver_nationality
    constructor_ref,
    constructor_name,
    constructor_nationality
from 
    results
    inner join races on results.race_id = races.race_id
    left join drivers on results.driver_id = drivers.driver_id
    left join constructors on results.constructor_id = constructors.constructor_id
  );
  
